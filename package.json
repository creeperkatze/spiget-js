{
  "name": "spiget-js",
  "version": "1.0.0",
  "description": "A framework-agnostic fully typed JavaScript client for the Spiget API",
  "homepage": "https://spiget-js.creeperkatze.dev",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "docs:api": "typedoc --options typedoc.json",
    "docs:dev": "concurrently -n typedoc,vitepress -c yellow,cyan \"typedoc --options typedoc.json --watch\" \"vitepress dev docs\"",
    "docs:build": "pnpm docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "release:patch": "pnpm version patch && git push && git push --tags",
    "release:minor": "pnpm version minor && git push && git push --tags",
    "release:major": "pnpm version major && git push && git push --tags"
  },
  "keywords": [
    "spiget",
    "spigotmc",
    "minecraft",
    "plugins",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/creeperkatze/spiget-js"
  },
  "bugs": {
    "url": "https://github.com/creeperkatze/spiget-js/issues"
  },
  "author": "Creeperkatze",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lucide/vue": "^1.20.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite-svg-loader": "^5.1.1",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.9"
  }
}
